SetupScreen {
    background: #0a0a0a;
}

#setup-container {
    margin: 0 4;
}

#version {
    margin-bottom: 1;
}

#tagline {
    margin-bottom: 2;
}

.checklist-row {
    margin-left: 2;
    margin-bottom: 0;
}

.checklist-row Button {
    margin-left: 1;
    background: transparent;
    border: none;
    color: $text-muted;
}

.checklist-row Button:hover {
    color: $primary;
}

.checklist-item {
    margin-left: 2;
}
