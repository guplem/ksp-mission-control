launch target_altitude=25_000 final_pitch=45
sas        mode=prograde

# Get rid of the remaining weight once apogee is the desired altitude
wait_for   below_current_thrust=0
wait_for   time=2
stage

wait_for   above_altitude=18_500
wait_for   biome=Water
sas        mode=retrograde

wait_for   below_altitude=1_500
parachutes
