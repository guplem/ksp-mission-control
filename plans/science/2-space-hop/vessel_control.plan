# Space hop with parallel science collection
# Flight track handles ascent and landing while the science track
# independently waits for conditions and collects experiments.

# Flight sequence
suborbital_launch   auto_stage

# Aerobrake and deploy chutes
wait_for   apoapsis=True
aerobreak   auto_stage=True
parachutes     min_altitude=10_000  stage_for_parachutes=True  wait_for_safe=True
